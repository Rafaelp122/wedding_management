          description: 'Formato: 00.000.000/0000-00'
          maxLength: 18
        phone:
          type: string
          title: Telefone
          description: 'Formato: (00) 00000-0000'
          maxLength: 20
        email:
          type: string
          format: email
          title: E-mail
          maxLength: 254
        is_active:
          type: boolean
          title: Ativo
          description: Fornecedor disponível para novos contratos
      required:
      - name
    TokenRefresh:
      type: object
      properties:
        access:
          type: string
          readOnly: true
      required:
      - access
    TokenRefreshRequest:
      type: object
      properties:
        refresh:
          type: string
          writeOnly: true
          minLength: 1
      required:
      - refresh
    Wedding:
      type: object
      description: Serializador para casamentos, incluindo dados básicos e orçamento
        inicial.
      properties:
        uuid:
          type: string
          format: uuid
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        groom_name:
          type: string
          maxLength: 100
        bride_name:
          type: string
          maxLength: 100
        date:
          type: string
          format: date
        location:
          type: string
          maxLength: 255
        expected_guests:
          type: integer
          maximum: 2147483647
          minimum: 0
          nullable: true
          title: Número de Convidados
          description: Quantidade estimada de convidados
        status:
          $ref: '#/components/schemas/WeddingStatusEnum'
      required:
      - bride_name
      - created_at
      - date
      - groom_name
      - location
      - updated_at
      - uuid
    WeddingRequest:
      type: object
      description: Serializador para casamentos, incluindo dados básicos e orçamento
        inicial.
      properties:
        groom_name:
          type: string
          minLength: 1
          maxLength: 100
        bride_name:
          type: string
          minLength: 1
          maxLength: 100
        date:
          type: string
          format: date
        location:
          type: string
          minLength: 1
          maxLength: 255
        expected_guests:
          type: integer
          maximum: 2147483647
          minimum: 0
          nullable: true
          title: Número de Convidados
          description: Quantidade estimada de convidados
        status:
          $ref: '#/components/schemas/WeddingStatusEnum'
        total_estimated:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
          writeOnly: true
          description: Valor total do orçamento inicial que será criado para este
            casamento.
      required:
      - bride_name
      - date
      - groom_name
      - location
      - total_estimated
    WeddingStatusEnum:
      enum:
      - IN_PROGRESS
      - COMPLETED
      - CANCELED
      type: string
      description: |-
        * `IN_PROGRESS` - Em Andamento
        * `COMPLETED` - Concluído
        * `CANCELED` - Cancelado
  securitySchemes:
    jwtAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
