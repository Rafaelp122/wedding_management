components:
  schemas:
    Budget:
      type: object
      description: Serializer para o Orçamento Mestre.
      properties:
        uuid:
          type: string
          format: uuid
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        wedding:
          type: string
          format: uuid
          description: UUID do Casamento vinculado
        total_estimated:
          type: string
          format: decimal
