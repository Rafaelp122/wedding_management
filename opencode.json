{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-magi"
  ],
  "agent": {
    "build": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "*": "allow",
          "git push*": "ask"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": "ask",
        "task": {
          "*": "deny"
        }
      }
    }
  },
  "lsp": {
    "typescript": {
      "command": ["npx", "typescript-language-server", "--stdio"],
      "disabled": false
    }
  },
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    }
  }
}
