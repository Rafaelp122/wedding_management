{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "*": "allow",
          "git push*": "ask"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.1,
      "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": "ask",
        "task": {
          "*": "deny"
        }
      }
    }
  }
}
