---
import ThemeToggle from './ThemeToggle';
---

<header class="sticky top-0 w-full bg-white/80 dark:bg-surface-dark/85 backdrop-blur-md border-b border-zinc-200/50 dark:border-zinc-800/80 z-50">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logótipo -->
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-aura-600 flex items-center justify-center shadow-glow">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="13" r="5.5" />
          <circle cx="15" cy="11" r="5.5" />
        </svg>
      </div>
      <span class="font-display font-bold text-lg tracking-tight text-zinc-950 dark:text-white">Sim, Aceito!</span>
    </div>

    <!-- Links de Menu -->
    <nav class="hidden md:flex items-center gap-8 text-xs font-semibold uppercase tracking-wider text-zinc-600 dark:text-zinc-400">
      <a href="#modulos" class="hover:text-aura-600 dark:hover:text-aura-400 btn-transition">Módulos</a>
      <a href="#simulador" class="hover:text-aura-600 dark:hover:text-aura-400 btn-transition flex items-center gap-1">
        Simulador de Orçamento <span class="bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 px-1.5 py-0.5 rounded text-[8px] font-bold">Interativo</span>
      </a>
      <a href="#precos" class="hover:text-aura-600 dark:hover:text-aura-400 btn-transition">Preços</a>
      <a href="#faq" class="hover:text-aura-600 dark:hover:text-aura-400 btn-transition">Perguntas</a>
    </nav>

    <!-- Ações -->
    <div class="flex items-center gap-4">
      <!-- Theme Toggle -->
      <ThemeToggle client:load />

      <!-- Login Link -->
      <a
        href="https://app.simaceito.site/login"
        class="text-zinc-600 dark:text-zinc-300 hover:text-aura-600 dark:hover:text-aura-400 text-xs font-bold uppercase tracking-wider btn-transition px-3 py-2 rounded-lg"
      >
        Login
      </a>

      <!-- Register Link -->
      <a
        href="https://app.simaceito.site/register"
        class="bg-aura-600 hover:bg-aura-700 text-white px-4 py-2 rounded-lg text-xs font-bold uppercase tracking-wider btn-transition shadow-sm shadow-aura-500/10 text-center"
      >
        Começar Agora
      </a>
    </div>

  </div>
</header>
