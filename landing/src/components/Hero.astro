---
---

<section class="relative pt-12 pb-20 lg:pt-24 lg:pb-32 px-6 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(124,58,237,0.06),transparent_50%)] pointer-events-none"></div>
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">

    <!-- Hero Text Info -->
    <div class="lg:col-span-6 space-y-6 text-center lg:text-left">
      <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-aura-100 dark:bg-aura-900/20 text-aura-700 dark:text-aura-300 text-xs font-semibold">
        <span>⚡</span> O ERP definitivo para assessorias de casamento
      </div>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-zinc-950 dark:text-white tracking-tight leading-none">
        Gestão <span class="text-transparent bg-clip-text bg-gradient-to-r from-aura-600 to-indigo-500">impecável</span> para assessorar sem estresse.
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400 text-base sm:text-lg max-w-xl mx-auto lg:mx-0 font-medium leading-relaxed">
        Elimine faturas atrasadas, centralize o diretório de fornecedores contratados, sincronize checklists por fases e compartilhe relatórios financeiros em segundos. Tudo em uma interface limpa, rápida e livre de fadiga.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
        <a
          href="https://app.simaceito.site/register"
          class="w-full sm:w-auto px-8 py-4 bg-aura-600 hover:bg-aura-700 text-white font-bold rounded-xl btn-transition shadow-lg shadow-aura-500/25 active:scale-95 text-sm uppercase tracking-wider text-center"
        >
          Começar Teste Gratuito de 14 Dias
        </a>
        <a href="#simulador" class="w-full sm:w-auto px-6 py-4 bg-zinc-100 dark:bg-zinc-800 text-zinc-800 dark:text-zinc-200 font-bold rounded-xl btn-transition text-center text-sm border border-zinc-200/50 dark:border-zinc-700/50 hover:bg-zinc-200 dark:hover:bg-zinc-700">
          📊 Simulador de Orçamento
        </a>
      </div>
      <div class="flex items-center justify-center lg:justify-start gap-6 text-xs text-zinc-500 dark:text-zinc-500 font-semibold uppercase tracking-wider">
        <span>💳 Sem cartão de crédito</span>
        <span>•</span>
        <span>⚡ Ativação imediata</span>
      </div>
    </div>

    <!-- Hero Mockup (CSS Dashboard preview) -->
    <div class="lg:col-span-6 relative">
      <div class="absolute -inset-2 bg-gradient-to-r from-aura-500 to-indigo-500 rounded-2xl opacity-15 blur-xl"></div>
      <div class="bg-white dark:bg-surface-darkSecondary rounded-xl border border-zinc-200 dark:border-zinc-800 shadow-2xl overflow-hidden relative">
        <!-- Dashboard Header mockup bar -->
        <div class="bg-zinc-50 dark:bg-zinc-900 border-b border-zinc-200/50 dark:border-zinc-800/80 px-4 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-red-400 inline-block"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-400 inline-block"></span>
            <span class="w-3 h-3 rounded-full bg-green-400 inline-block"></span>
          </div>
          <span class="text-[10px] font-mono font-medium text-zinc-400">simaceito.site/casamento/julia-marcos</span>
          <div class="w-4"></div>
        </div>

        <!-- Inner mock content screen -->
        <div class="p-6 space-y-4 text-left">
          <!-- Head info -->
          <div class="flex items-center justify-between border-b border-zinc-100 dark:border-zinc-800 pb-3">
            <div>
              <h4 class="font-display font-bold text-base text-zinc-950 dark:text-white">Júlia & Marcos</h4>
              <p class="text-[10px] text-zinc-400 font-medium">🗓️ 20 Set 2026 • Fazenda Vila Rica, SP</p>
            </div>
            <span class="bg-emerald-500/10 text-emerald-650 dark:text-emerald-400 text-[10px] px-2.5 py-0.5 rounded-full font-bold">58% Utilizado</span>
          </div>

          <!-- Progress Bar & Cash Info -->
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-zinc-50/50 dark:bg-zinc-900/20 p-3 rounded-lg border border-zinc-100 dark:border-zinc-800/50">
              <span class="text-[9px] font-bold text-zinc-400 uppercase tracking-wider block">Orçado</span>
              <span class="font-mono text-base font-bold text-zinc-900 dark:text-white">R$ 145.000,00</span>
            </div>
            <div class="bg-zinc-50/50 dark:bg-zinc-900/20 p-3 rounded-lg border border-zinc-100 dark:border-zinc-800/50">
              <span class="text-[9px] font-bold text-zinc-400 uppercase tracking-wider block">Gasto Realizado</span>
              <span class="font-mono text-base font-bold text-emerald-600 dark:text-emerald-400">R$ 84.500,00</span>
            </div>
          </div>

          <!-- Mini Installment Alert card -->
          <div class="bg-red-500/5 dark:bg-red-950/10 p-3 rounded-lg border-2 border-red-500 dark:border-red-900/30 flex items-center justify-between">
            <div>
              <span class="text-[9px] font-bold text-red-500 uppercase tracking-wider">Atraso Detectado</span>
              <h5 class="text-xs font-semibold mt-0.5 text-zinc-900 dark:text-white">Som & Luz Produções — Parcela 2</h5>
            </div>
            <span class="font-mono text-xs font-bold text-red-650 dark:text-red-400">R$ 4.500,00</span>
          </div>

          <!-- Checklist block with fixed custom checkboxes -->
          <div class="space-y-2">
            <h5 class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider">Fase 1: Checklist Crítico</h5>
            <div class="space-y-2 text-[11px] font-medium text-zinc-700 dark:text-zinc-300">
              <div class="flex items-center gap-2">
                <div class="w-3.5 h-3.5 rounded bg-aura-600 border border-aura-600 flex items-center justify-center shrink-0 text-white">
                  <svg aria-hidden="true" class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="line-through opacity-60"><span class="sr-only">(Concluído) </span>Visita técnica detalhada ao espaço campestre</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-3.5 h-3.5 rounded bg-aura-600 border border-aura-600 flex items-center justify-center shrink-0 text-white">
                  <svg aria-hidden="true" class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <span class="line-through opacity-60"><span class="sr-only">(Concluído) </span>Aprovação do layout de cobertura transparente</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-3.5 h-3.5 rounded border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 shrink-0"></div>
                <span><span class="sr-only">(Pendente) </span>Contratação e dimensionamento de gerador de suporte</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
